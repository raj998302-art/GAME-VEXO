{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile data",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "user", "developer"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role"]
    },
    "Game": {
      "title": "Game",
      "description": "Game metadata",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "slug": { "type": "string" },
        "description": { "type": "string" },
        "category": { "type": "string" },
        "thumbnail": { "type": "string" },
        "gameUrl": { "type": "string" },
        "developerId": { "type": "string" },
        "developerName": { "type": "string" },
        "status": { "type": "string", "enum": ["draft", "pending", "approved", "rejected"] },
        "views": { "type": "number" },
        "likes": { "type": "number" },
        "playTime": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "slug", "developerId", "status"]
    },
    "SupportChat": {
      "title": "SupportChat",
      "description": "Support chat session",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "sender": { "type": "string", "enum": ["user", "admin"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "messages"]
    },
    "PayoutRequest": {
      "title": "PayoutRequest",
      "description": "Developer payout request",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "upiDetails": { "type": "string" },
        "amountRequested": { "type": "string" },
        "proofScreenshotUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "upiDetails", "amountRequested", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profiles"
    },
    "/games/{gameId}": {
      "schema": { "$ref": "#/entities/Game" },
      "description": "Games"
    },
    "/supportChats/{chatId}": {
      "schema": { "$ref": "#/entities/SupportChat" },
      "description": "Support chats"
    },
    "/payouts/{payoutId}": {
      "schema": { "$ref": "#/entities/PayoutRequest" },
      "description": "Payout requests from developers"
    }
  }
}
